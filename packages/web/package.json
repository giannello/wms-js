{
  "name": "@warema/web",
  "type": "module",
  "main": "dist/packages/web/src/index.js",
  "types": "dist/packages/web/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:discovery": "esbuild src/ui.tsx --bundle --outfile=public/discovery-bundle.js --format=esm --platform=browser --jsx=automatic --external:react --external:react-dom",
