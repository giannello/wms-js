{
  "name": "@wms-js/web",
  "type": "module",
  "main": "dist/packages/web/src/index.js",
  "types": "dist/packages/web/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:discovery": "esbuild src/ui.tsx --bundle --outfile=public/discovery-bundle.js --format=esm --platform=browser --jsx=automatic --external:react --external:react-dom",
    "build:home": "esbuild src/home.tsx --bundle --outfile=public/home-bundle.js --format=esm --platform=browser --jsx=automatic --external:react --external:react-dom",
    "build:pages": "npm run build:discovery && npm run build:home"
  },
  "dependencies": {
    "@wms-js/lib": "*"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
